# Copy to `.env` and fill in real values. docker-compose.yaml auto-loads `.env`.
# `.env` is gitignored — never commit real domains, emails, or DB secrets.

# --- Production HTTPS (nginx-proxy + acme-companion) ---
# Public domain whose DNS A/AAAA record points at this Docker host.
# Ports 80 and 443 must be reachable from the internet for ACME to issue certs.
PROD_DOMAIN=cv.example.com
# Email Let's Encrypt uses for expiry notices.
ACME_EMAIL=you@example.com

# --- Database (optional overrides; compose has built-in defaults) ---
# DB_NAME=cv_analyser
# DB_USER=cv_user
# DB_PASSWORD=changeme
